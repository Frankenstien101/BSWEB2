{# ---------------------------------------------------------------------
 # GLPI - Gestionnaire Libre de Parc Informatique
 # Customized for DELIVERY DASH - Modern Dark Theme
 # --------------------------------------------------------------------- #}
{% extends 'layout/page_card_notlogged.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="{{ asset('Services/img/dash.png') }}">

    <style>
        :root {
            --navy-blue: #0A1931;
            --navy-blue-light: #13274F;
            --navy-blue-dark: #07121F;
            --deep-orange: #FF5F00;
            --deep-orange-light: #FF7F33;
            --deep-orange-dark: #CC4C00;
            --text: #f8fafc;
            --text-light: #e2e8f0;
            --text-muted: #94a3b8;
            --bg-dark: #0f172a;
            --card-bg: rgba(10, 25, 49, 0.9);
            --error: #ef4444;
            --error-bg: rgba(239, 68, 68, 0.15);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            color: var(--text);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-image: url('{{ asset('MainImg/DELIVERY.jpg') }}');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            position: relative;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(10, 25, 49, 0.85);
            z-index: -1;
        }

        /* Navigation Bar */
        .glpi-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            background-color: rgba(10, 25, 49, 0.9);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255, 95, 0, 0.2);
            z-index: 10;
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .nav-logo img {
            height: 36px;
        }

        .nav-logo span {
            font-weight: 600;
            color: var(--text);
            font-size: 1.05rem;
        }

        .nav-links {
            display: flex;
            gap: 1.5rem;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-light);
            font-size: 0.875rem;
            font-weight: 500;
            padding: 0.5rem;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .nav-links a:hover {
            color: var(--deep-orange);
            background: rgba(255, 95, 0, 0.1);
        }

        /* Login Container */
        .login-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
            z-index: 1;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--card-bg);
            border-radius: 12px;
            backdrop-filter: blur(8px);
            padding: 2.5rem;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.2);
        }

        .logo {
            text-align: center;
            margin-bottom: 2rem;
        }

        .logo img {
            height: 120px;
            margin-bottom: -1rem;
        }

        .logo h1 {
            font-size: 1.75rem;
            font-weight: 700;
            margin-top: 0.75rem;
            letter-spacing: 0.5px;
            background: linear-gradient(45deg, var(--text-light), var(--deep-orange-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        h2 {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 1.75rem;
            text-align: center;
            color: var(--text);
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        label {
            display: block;
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
            color: var(--text-light);
        }

        .form-control {
            width: 100%;
            padding: 0.875rem;
            background: rgba(19, 39, 79, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            font-size: 0.9375rem;
            color: var(--text);
            transition: all 0.25s ease;
        }

        .form-control::placeholder {
            color: var(--text-muted);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--deep-orange);
            background: rgba(19, 39, 79, 0.8);
            box-shadow: 0 0 0 2px rgba(255, 95, 0, 0.25);
        }

        .form-check {
            display: flex;
            align-items: center;
            margin: 1.5rem 0;
            gap: 0.75rem;
        }

        .form-check-input {
            accent-color: var(--deep-orange);
            margin: 0;
        }

        .form-check-label {
            margin: 0;
            color: var(--text-light);
            font-size: 0.875rem;
        }

        .btn-primary {
            width: 100%;
            padding: 0.875rem;
            background-color: var(--deep-orange);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 0.9375rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.25s ease;
            margin-top: 0.5rem;
        }

        .btn-primary:hover {
            background-color: var(--deep-orange-dark);
            transform: translateY(-1px);
        }

        .form-label-description {
            float: right;
            font-size: 0.8rem;
        }

        .form-label-description a {
            color: var(--deep-orange-light);
            text-decoration: none;
        }

        .form-label-description a:hover {
            text-decoration: underline;
        }

        .alert-danger {
            color: var(--error);
            background: var(--error-bg);
            font-size: 0.875rem;
            margin: 1.25rem 0;
            padding: 0.875rem;
            border-radius: 8px;
            text-align: center;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .rich_text_container {
            color: var(--text-light);
            font-size: 0.875rem;
            line-height: 1.5;
            margin-bottom: 1.5rem;
        }

        .btn-outline-secondary {
            margin-top: 1rem;
            color: var(--text-light);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .btn-outline-secondary:hover {
            background: rgba(255, 95, 0, 0.1);
            color: var(--deep-orange);
            border-color: var(--deep-orange);
        }

        .footer {
            text-align: center;
            padding: 1.5rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            z-index: 1;
        }

        @media (max-width: 640px) {
            .glpi-nav {
                padding: 1rem;
                flex-direction: column;
                gap: 0.75rem;
            }
            .nav-links {
                gap: 1rem;
            }
            .login-card {
                padding: 2rem 1.5rem;
            }
        }
    </style>
{% endblock %}

{% block content_block %}
    <!-- Navigation -->
    <nav class="glpi-nav">
        <div class="nav-logo">
            <img src="{{ asset('MainImg/download-compresskaru.com.png') }}" alt="Bluesys Logo">
            <span>BLUESYS APPLICATIONS</span>
        </div>
        <div class="nav-links">
            <a href="{{ path('front/helpdesk.public.php') }}?contact=1">{{ __('Contact') }}</a>
            <a href="{{ path('front/helpdesk.public.php') }}?about=1">{{ __('About') }}</a>
            <a href="{{ path('front/helpdesk.public.php') }}?services=1">{{ __('Services') }}</a>
        </div>
    </nav>

    <!-- Login Form -->
    <div class="login-container">
        <div class="login-card">
            <div class="logo">
                <img src="{{ asset('Services/img/dash.png') }}" alt="DELIVERY DASH Logo">
                <h1>DELIVERY DASH</h1>
            </div>

            <h2>{{ __('Login to your account') }}</h2>

            <form action="{{ path('front/login.php') }}" method="post" autocomplete="off" data-submit-once>
                <input type="hidden" name="noAUTO" value="{{ noAuto }}" />
                <input type="hidden" name="redirect" value="{{ redirect }}" />
                <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}" />

                <div class="form-group">
                    <label for="login_name">{{ __('Login') }}</label>
                    <input type="text" class="form-control" id="login_name" name="{{ namfield }}" placeholder="" tabindex="1" required autofocus />
                </div>

                <div class="form-group">
                    <label for="login_password">
                        {{ __('Password') }}
                        {% if show_lost_password %}
                            <span class="form-label-description">
                                <a href="{{ path('front/lostpassword.php?lostpassword=1') }}">{{ __('Forgotten password?') }}</a>
                            </span>
                        {% endif %}
                    </label>
                    <input type="password" class="form-control" id="login_password" name="{{ pwdfield }}" placeholder="" autocomplete="off" tabindex="2" required />
                </div>

                {% if constant('GLPI_DEMO_MODE') %}
                    <div class="form-group">
                        <label for="dropdown_language{{ rand }}">{{ __('Language') }}</label>
                        {{ languages_dropdown|raw }}
                    </div>
                {% endif %}

                {% if config('display_login_source') %}
                    <div class="form-group">
                        <label for="dropdown_auth{{ rand }}">{{ __('Login source') }}</label>
                        {{ auth_dropdown_login|raw }}
                    </div>
                {% endif %}

                {% if config('login_remember_time') %}
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="login_remember" name="{{ rmbfield }}" {{ config('login_remember_default') ? 'checked' : '' }} />
                        <label class="form-check-label" for="login_remember">{{ __('Remember me') }}</label>
                    </div>
                {% endif %}

                <button type="submit" name="submit" class="btn-primary" tabindex="3">
                    {{ __('Sign in') }}
                </button>

                {% if errors|length > 0 %}
                    <div class="alert alert-danger" role="alert">
                        {{ errors }}
                    </div>
                {% endif %}
            </form>

            {% if right_panel %}
                <div class="mt-4 text-center">
                    {% if text_login|length > 0 %}
                        <div class="rich_text_container">
                            {{ text_login|safe_html }}
                        </div>
                    {% endif %}

                    {% if config('use_public_faq') %}
                        <hr />
                        <a class="btn btn-outline-secondary btn-icon" href="front/helpdesk.faq.php">
                            <i class="fas fa-question"></i>&nbsp;{{ __('FAQ') }}
                        </a>
                    {% endif %}

                    {{ call_plugin_hook(constant('Glpi\\Plugin\\Hooks::DISPLAY_LOGIN')) }}
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block footer_block %}
    <div class="footer">
        © {{ "now"|date("Y") }} DELIVERY DASH. {{ __('All rights reserved.') }}
    </div>
{% endblock %}

{% block javascript_block %}
    {{ parent() }}
    <script type="text/javascript">
        $(function () {
            $('#login_name').focus();
        });
    </script>
{% endblock %}